- \uc0\u44256 \u44061 \u51060  \u50616 \u44553 \u54620  \u50836 \u44396 \u49324 \u54637 , \u55148 \u47581 \u49324 \u54637 , \u51228 \u50557  \u51312 \u44148 , \u50864 \u47140  \u49324 \u54637 , \u54869 \u51064  \u50836 \u52397  \u49324 \u54637  \u51473  \u54532 \u47196 \u51229 \u53944  \u51652 \u54665 \u50640  \u50689 \u54693 \u51012  \u51460  \u49688  \u51080 \u45716  \u45236 \u50857 \u51008  \u45572 \u46973 \u54616 \u51648  \u50506 \u45716 \u45796 .\
- \uc0\u48152 \u46300 \u49884  \u51652 \u54665 \u54616 \u44592 \u47196  \u54869 \u51221 \u46108  \u45236 \u50857 \u44284  \u45800 \u49692  \u55148 \u47581 \u49324 \u54637 , \u52280 \u44256 \u49324 \u54637 , \u44160 \u53664  \u51473 \u51064  \u49324 \u54637 \u51012  \u44396 \u48516 \u54620 \u45796 .\
- \uc0\u45236 \u48512 \u51201 \u51004 \u47196  \u51068 \u51221 , \u48276 \u50948 , \u48708 \u50857 , \u45812 \u45817 \u51088 , \u44592 \u49696  \u44396 \u54788  \u52769 \u47732 \u50640 \u49436  \u47532 \u49828 \u53356 \u44032  \u51080 \u44144 \u45208  \u51116 \u54869 \u51064 \u51060  \u54596 \u50836 \u54620  \u48512 \u48516 \u51008  \u54869 \u51064  \u54596 \u50836  \u49324 \u54637  \u46608 \u45716  \u44032 \u45733 \u54620  \u47532 \u49828 \u53356 \u47196  \u48516 \u47532 \u54620 \u45796 .\
