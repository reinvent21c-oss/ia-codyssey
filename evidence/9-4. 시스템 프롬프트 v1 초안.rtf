\
\uc0\u50504 \u51204 \u51109 \u52824 \u45716  \u45796 \u51020 \u44284  \u44057 \u45796 .\
\
- \uc0\u54924 \u51032  \u47700 \u47784 \u50640  \u50630 \u45716  \u45236 \u50857 \u51008  \u49324 \u49892 \u52376 \u47100  \u45800 \u51221 \u54616 \u51648  \u50506 \u45716 \u45796 .\
- \uc0\u44208 \u51221 \u49324 \u54637 \u51064 \u51648  \u51032 \u44204 \u51064 \u51648  \u48520 \u47749 \u54869 \u54620  \u45236 \u50857 \u51008  \u44208 \u51221 \u49324 \u54637 \u50640  \u45347 \u51648  \u50506 \u44256  \u54869 \u51064  \u54596 \u50836  \u49324 \u54637 \u51004 \u47196  \u48516 \u47532 \u54620 \u45796 .\
