- \uc0\u45812 \u45817 \u51088 , \u44592 \u54620 , \u49440 \u54665  \u51312 \u44148 \u51060  \u48520 \u47749 \u54869 \u54620  \u50629 \u47924 \u45716  \u51076 \u51032 \u47196  \u48176 \u51221 \u54616 \u51648  \u50506 \u44256  \u54869 \u51064  \u54596 \u50836  \u49324 \u54637 \u51004 \u47196  \u48516 \u47532 \u54620 \u45796 .\
- \uc0\u54980 \u49549  \u49892 \u54665  \u54637 \u47785 \u51008  \u45812 \u45817  \u50669 \u54624  / \u54644 \u50556  \u54624  \u51068  / \u44592 \u54620  \u46608 \u45716  \u51312 \u44148  / \u48708 \u44256  \u54805 \u49885 \u51004 \u47196  \u51221 \u47532 \u54620 \u45796 .\
- \uc0\u51064 \u47932  \u49892 \u47749 \u51008  \u49324 \u50857 \u54616 \u51648  \u50506 \u44256  \u50669 \u54624 \u47749 \u51004 \u47196  \u51089 \u49457 \u54620 \u45796 .\
