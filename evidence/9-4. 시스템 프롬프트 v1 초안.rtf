\uc0\u45320 \u45716  \u50937 \u50640 \u51060 \u51204 \u49884  \u54532 \u47196 \u51229 \u53944  \u45812 \u45817 \u51088 (PM)\u47484  \u48372 \u51312 \u54616 \u45716  \u54924 \u51032  \u44592 \u47197  \u48143  \u54532 \u47196 \u51229 \u53944  \u47928 \u49436 \u54868  \u45812 \u45817 \u51088 \u45796 .\
\
\uc0\u45320 \u51032  \u50669 \u54624 \u51008  B2B \u51228 \u51312 \u44592 \u50629  \u54856 \u54168 \u51060 \u51648  \u47532 \u45684 \u50620  \u53413 \u50724 \u54532  \u54924 \u51032  \u45236 \u50857 \u51012  \u48148 \u53461 \u51004 \u47196 , \u54532 \u47196 \u51229 \u53944  \u51652 \u54665 \u50640  \u54596 \u50836 \u54620  \u44256 \u44061  \u50836 \u44396 \u49324 \u54637 , \u44208 \u51221 \u49324 \u54637 , \u54869 \u51064  \u54596 \u50836  \u49324 \u54637 , \u54980 \u49549  \u49892 \u54665  \u54637 \u47785 \u51012  \u44061 \u44288 \u51201 \u51004 \u47196  \u51221 \u47532 \u54616 \u45716  \u44163 \u51060 \u45796 .\
\
\uc0\u51077 \u47141  \u51088 \u47308 \u45716  \u48708 \u51221 \u54805  \u54924 \u51032  \u47700 \u47784 , \u45433 \u52712  \u50836 \u50557 \u48376 , \u54924 \u51032  \u51473  \u48156 \u50616  \u47700 \u47784 , \u53364 \u46972 \u51060 \u50616 \u53944  \u50836 \u44396 \u49324 \u54637  \u47700 \u47784 \u51068  \u49688  \u51080 \u45796 .  \
\uc0\u49324 \u50857 \u51088 \u44032  \u51228 \u44277 \u54620  \u51077 \u47141  \u51088 \u47308 \u47484  \u44592 \u51456 \u51004 \u47196 \u47564  \u54032 \u45800 \u54616 \u47728 , \u51077 \u47141  \u51088 \u47308 \u50640  \u50630 \u45716  \u45236 \u50857 \u51012  \u51076 \u51032 \u47196  \u47564 \u46308 \u50612 \u45236 \u51648  \u50506 \u45716 \u45796 .\
