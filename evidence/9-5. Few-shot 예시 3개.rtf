#### \uc0\u44592 \u45824  \u52636 \u47141 \
\
1. \uc0\u54924 \u51032  \u47785 \u51201 \
- \uc0\u54856 \u54168 \u51060 \u51648  \u47532 \u45684 \u50620  \u54596 \u50836 \u49457 \u44284  \u51228 \u54408  \u54168 \u51060 \u51648 , \u46356 \u51088 \u51064  \u48169 \u54693 , \u47928 \u51032  \u44592 \u45733  \u44032 \u45733 \u49457 \u50640  \u45824 \u54644  \u45436 \u51032 \u54620  \u44163 \u51004 \u47196  \u48372 \u51077 \u45768 \u45796 .\
- \uc0\u45796 \u47564  \u51077 \u47141  \u51221 \u48372 \u44032  \u48512 \u51313 \u54616 \u50668  \u54869 \u51221 \u46108  \u54924 \u51032  \u47785 \u51201 \u51008  \u52628 \u44032  \u54869 \u51064 \u51060  \u54596 \u50836 \u54633 \u45768 \u45796 .\
\
2. \uc0\u44208 \u51221 \u49324 \u54637 \
- \uc0\u54924 \u51032  \u47700 \u47784 \u47564 \u51004 \u47196 \u45716  \u54869 \u51221 \u46108  \u44208 \u51221 \u49324 \u54637 \u51012  \u54032 \u45800 \u54616 \u44592  \u50612 \u47157 \u49845 \u45768 \u45796 .\
\
3. \uc0\u54980 \u49549  \u49892 \u54665  \u54637 \u47785 \
\
| \uc0\u45812 \u45817  \u50669 \u54624  | \u54644 \u50556  \u54624  \u51068  | \u44592 \u54620  \u46608 \u45716  \u51312 \u44148  | \u48708 \u44256  |\
|---|---|---|---|\
| \uc0\u53364 \u46972 \u51060 \u50616 \u53944  \u45812 \u45817 \u51088  | \u54856 \u54168 \u51060 \u51648  \u47532 \u45684 \u50620  \u44288 \u47144  \u51088 \u47308  \u51204 \u45804  | \'93\u45208 \u51473 \u50640 \'94\u47196 \u47564  \u50616 \u44553 \u46120  | \u51221 \u54869 \u54620  \u51204 \u45804  \u44592 \u54620  \u54869 \u51064  \u54596 \u50836  |\
| \uc0\u50937 \u50640 \u51060 \u51204 \u49884  \u54532 \u47196 \u51229 \u53944  \u45812 \u45817 \u51088 (PM) | \u51228 \u54408  \u54168 \u51060 \u51648  \u51473 \u50836 \u46020 \u50752  \u44396 \u49457  \u48276 \u50948  \u54869 \u51064  | \u54869 \u51064  \u54596 \u50836  | \u54645 \u49900  \u54168 \u51060 \u51648  \u50668 \u48512  \u54869 \u51064  \u54596 \u50836  |\
| \uc0\u50937 \u50640 \u51060 \u51204 \u49884  \u54532 \u47196 \u51229 \u53944  \u45812 \u45817 \u51088 (PM) | \u47928 \u51032  \u44592 \u45733  \u54252 \u54632  \u50668 \u48512  \u54869 \u51064  | \u54869 \u51064  \u54596 \u50836  | \'93\u54596 \u50836 \u54624  \u49688 \u46020  \u51080 \u51020 \'94\u51004 \u47196  \u50616 \u44553 \u46104 \u50612  \u54869 \u51221  \u50500 \u45784  |\
| \uc0\u50937 \u50640 \u51060 \u51204 \u49884  \u54532 \u47196 \u51229 \u53944  \u45812 \u45817 \u51088 (PM) | \u49324 \u51060 \u53944 \u47605  \u54869 \u51221  \u50668 \u48512  \u48143  \u51204 \u45804  \u44032 \u45733  \u51068 \u51221  \u54869 \u51064  | \'93\u45236 \u48512  \u51228 \u51089  \u51473 \'94\u51004 \u47196 \u47564  \u50616 \u44553 \u46120  | \u47728 \u52832  \u54980  \u51116 \u54869 \u51064  \u54596 \u50836  |\
\
4. \uc0\u54869 \u51064 \u46108  \u49324 \u49892 \
- \uc0\u54856 \u54168 \u51060 \u51648  \u47532 \u45684 \u50620  \u54596 \u50836 \u49457 \u51060  \u50616 \u44553 \u46104 \u50632 \u49845 \u45768 \u45796 .\
- \uc0\u51228 \u54408  \u54168 \u51060 \u51648 \u44032  \u51473 \u50836 \u54616 \u45796 \u45716  \u51032 \u44204 \u51060  \u51080 \u50632 \u49845 \u45768 \u45796 .\
- \uc0\u44628 \u45140 \u54620  \u46356 \u51088 \u51064  \u48169 \u54693 \u51060  \u50616 \u44553 \u46104 \u50632 \u49845 \u45768 \u45796 .\
- \uc0\u47928 \u51032  \u44592 \u45733 \u51008  \u44032 \u45733 \u49457  \u49688 \u51456 \u51004 \u47196  \u50616 \u44553 \u46104 \u50632 \u49845 \u45768 \u45796 .\
- \uc0\u49324 \u51060 \u53944 \u47605 \u51008  \u45236 \u48512  \u51228 \u51089  \u51473 \u51060 \u45208  \u51204 \u45804  \u51068 \u51221 \u51008  \u51221 \u54644 \u51648 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
\
5. \uc0\u44032 \u45733 \u54620  \u47532 \u49828 \u53356 \
- \uc0\u51088 \u47308  \u51204 \u45804  \u44592 \u54620 \u51060  \u48520 \u47749 \u54869 \u54644  \u44592 \u54925  \u48143  \u46356 \u51088 \u51064  \u51068 \u51221 \u51060  \u51648 \u50672 \u46112  \u49688  \u51080 \u49845 \u45768 \u45796 .\
- \uc0\u47928 \u51032  \u44592 \u45733  \u54252 \u54632  \u50668 \u48512 \u44032  \u54869 \u51221 \u46104 \u51648  \u50506 \u50500  \u44060 \u48156  \u48276 \u50948 \u50752  \u44204 \u51201 \u51060  \u48320 \u46041 \u46112  \u49688  \u51080 \u49845 \u45768 \u45796 .\
- \uc0\u49324 \u51060 \u53944 \u47605  \u51204 \u45804  \u51068 \u51221 \u51060  \u48520 \u47749 \u54869 \u54644  \u54168 \u51060 \u51648  \u44396 \u51312  \u54869 \u51221 \u51060  \u51648 \u50672 \u46112  \u49688  \u51080 \u49845 \u45768 \u45796 .\
- \'93\uc0\u45796 \u51020  \u51452 \u52196 \'94\u51060 \u46972 \u45716  \u54364 \u54788 \u51060  \u47784 \u54840 \u54644  \u54980 \u49549  \u51068 \u51221  \u44288 \u47532 \u44032  \u50612 \u47140 \u50872  \u49688  \u51080 \u49845 \u45768 \u45796 .\
\
6. \uc0\u54869 \u51064  \u54596 \u50836  \u49324 \u54637 \
- \uc0\u47532 \u45684 \u50620 \u51032  \u44396 \u52404 \u51201 \u51064  \u47785 \u51201 \u51060  \u47924 \u50631 \u51064 \u51648  \u54869 \u51064 \u54644 \u50556  \u54633 \u45768 \u45796 .\
- \uc0\u51228 \u54408  \u54168 \u51060 \u51648 \u51032  \u44396 \u49457  \u48276 \u50948 \u50752  \u50864 \u49440 \u49692 \u50948 \u47484  \u54869 \u51064 \u54644 \u50556  \u54633 \u45768 \u45796 .\
- \uc0\u53364 \u46972 \u51060 \u50616 \u53944 \u44032  \u51204 \u45804 \u54624  \u51088 \u47308 \u51032  \u51333 \u47448 \u50752  \u51204 \u45804  \u44592 \u54620 \u51012  \u54869 \u51064 \u54644 \u50556  \u54633 \u45768 \u45796 .\
- \uc0\u47928 \u51032  \u44592 \u45733  \u54252 \u54632  \u50668 \u48512 \u47484  \u54869 \u51221 \u54644 \u50556  \u54633 \u45768 \u45796 .\
- \uc0\u49324 \u51060 \u53944 \u47605  \u51204 \u45804  \u44032 \u45733  \u51068 \u51221 \u44284  \u54869 \u51221  \u50668 \u48512 \u47484  \u54869 \u51064 \u54644 \u50556  \u54633 \u45768 \u45796 .\
- \'93\uc0\u45796 \u51020  \u51452 \u52196  \u51221 \u47532 \'94\u51032  \u51221 \u54869 \u54620  \u51068 \u51221 \u44284  \u45812 \u45817 \u51088 \u47484  \u54869 \u51064 \u54644 \u50556  \u54633 \u45768 \u45796 .\
\
7. \uc0\u54980 \u49549  \u51068 \u51221 \
- \uc0\u45796 \u51020  \u51452  \u51473  \u54980 \u49549  \u51221 \u47532 \u44032  \u50616 \u44553 \u46104 \u50632 \u51004 \u45208 , \u51221 \u54869 \u54620  \u45216 \u51676 \u50752  \u45812 \u45817 \u51088 \u45716  \u54869 \u51064 \u51060  \u54596 \u50836 \u54633 \u45768 \u45796 .\
\
\uc0\u52628 \u44032  \u54869 \u51064  \u51656 \u47928 \
- \uc0\u47532 \u45684 \u50620 \u51032  1\u49692 \u50948  \u47785 \u51201 \u51008  \u44592 \u50629  \u49888 \u47280 \u46020  \u44060 \u49440 , \u51228 \u54408  \u51221 \u48372  \u51204 \u45804 , \u47928 \u51032  \u51204 \u54872  \u51473  \u47924 \u50631 \u51064 \u44032 \u50836 ?\
- \uc0\u51228 \u54408  \u54168 \u51060 \u51648 \u50640 \u45716  \u51228 \u54408  \u47785 \u47197 , \u49345 \u49464  \u49444 \u47749 , \u52852 \u53448 \u47196 \u44536  \u45796 \u50868 \u47196 \u46300  \u51473  \u50612 \u46500  \u50836 \u49548 \u44032  \u54596 \u50836 \u54620 \u44032 \u50836 ?\
- \uc0\u51088 \u47308  \u51204 \u45804  \u50696 \u51221 \u51068 \u51008  \u50616 \u51228 \u51064 \u44032 \u50836 ?\
- \uc0\u47928 \u51032  \u44592 \u45733 \u51008  \u54596 \u49688  \u44592 \u45733 \u51064 \u44032 \u50836 , \u44160 \u53664  \u45824 \u49345 \u51064 \u44032 \u50836 ?\
- \uc0\u49324 \u51060 \u53944 \u47605 \u51008  \u50616 \u51228 \u44620 \u51648  \u51204 \u45804  \u44032 \u45733 \u54620 \u44032 \u50836 ?\
- \uc0\u45796 \u51020  \u51452  \u54980 \u49549  \u51221 \u47532 \u45716  \u45236 \u48512  \u51221 \u47532 \u51064 \u51648 , \u53364 \u46972 \u51060 \u50616 \u53944  \u51116 \u54924 \u51032 \u51064 \u51648  \u54869 \u51064 \u51060  \u54596 \u50836 \u54620 \u44032 \u50836 ?\
- \uc0\u52280 \u44256 \u54624  \u47112 \u54140 \u47088 \u49828  \u46608 \u45716  \u48292 \u52824 \u47560 \u53433  \u49324 \u51060 \u53944 \u44032  \u51080 \u45208 \u50836 ?}