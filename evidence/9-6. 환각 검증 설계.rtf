\
#### \uc0\u44592 \u45824  \u51221 \u45813  \u46608 \u45716  \u51221 \u45813  \u54032 \u51221  \u44592 \u51456 \
\uc0\u54924 \u51032  \u47700 \u47784 \u50640  \'93\u54924 \u49324 \u49548 \u44060 \u50752  \u51228 \u54408 \u49548 \u44060 \u45716  \u48152 \u46300 \u49884  \u54252 \u54632 \u54616 \u44592 \u47196  \u54664 \u45796 \'94\u52376 \u47100  \u47749 \u49884 \u46104 \u50612  \u51080 \u51004 \u47732  \u51228 \u54408 \u49548 \u44060  \u54168 \u51060 \u51648  \u54252 \u54632 \u51008  \u54869 \u51221 \u51004 \u47196  \u45813 \u54624  \u49688  \u51080 \u49845 \u45768 \u45796 .\
