\f0\fs24 \cf0 ## 9-6. \uc0\u54872 \u44033 (Hallucination) \u44160 \u51613  \u49444 \u44228 \
\
\uc0\u48376  \u44284 \u50629 \u50640 \u49436  \u54872 \u44033 \u51008  \u54924 \u51032  \u47700 \u47784 \u50640  \u47749 \u49884 \u46104 \u51648  \u50506 \u51008  \u49324 \u49892 , \u51068 \u51221 , \u45812 \u45817 \u51088 , \u44592 \u45733  \u48276 \u50948 , \u44208 \u51221 \u49324 \u54637 \u51012  AI\u44032  \u44540 \u44144  \u50630 \u51060  \u54869 \u51221 \u46108  \u44163 \u52376 \u47100  \u51089 \u49457 \u54616 \u45716  \u44221 \u50864 \u47196  \u51221 \u51032 \u54633 \u45768 \u45796 .\
\
\uc0\u54924 \u51032 \u47197  \u50836 \u50557  \u48143  \u54980 \u49549  \u49892 \u54665  \u54637 \u47785  \u51221 \u47532  \u50629 \u47924 \u50640 \u49436 \u45716  \u45800 \u49692 \u54620  \u47928 \u51109  \u54408 \u51656 \u48372 \u45796 , \u54924 \u51032  \u47700 \u47784 \u50640  \u51080 \u45716  \u45236 \u50857 \u44284  \u50630 \u45716  \u45236 \u50857 \u51012  \u44396 \u48516 \u54616 \u45716  \u45733 \u47141 \u51060  \u51473 \u50836 \u54633 \u45768 \u45796 .  \
\uc0\u46384 \u46972 \u49436  \u48376  \u44160 \u51613 \u51008  AI\u44032  \u54869 \u51064 \u46104 \u51648  \u50506 \u51008  \u45236 \u50857 \u51012  \u51076 \u51032 \u47196  \u47564 \u46308 \u50612 \u45236 \u51648  \u50506 \u44256 , \u54596 \u50836 \u54620  \u44221 \u50864  \'93\u54869 \u51064  \u54596 \u50836 \'94\u47196  \u48516 \u47532 \u54616 \u45716 \u51648  \u54869 \u51064 \u54616 \u45716  \u44163 \u51012  \u47785 \u54364 \u47196  \u54633 \u45768 \u45796 .\
\
### 1. \uc0\u44160 \u51613  \u44592 \u51456 \
\
#### Pass \uc0\u44592 \u51456 \
\
\uc0\u45796 \u51020  \u51473  \u54616 \u45208 \u47484  \u52649 \u51313 \u54616 \u47732  Pass\u47196  \u54032 \u51221 \u54633 \u45768 \u45796 .\
\
- A. \uc0\u54924 \u51032  \u47700 \u47784 \u50640  \u44540 \u44144 \u54620  \u51221 \u45813 \u51012  \u47582 \u55176 \u44256 , \u44036 \u45800 \u54620  \u44540 \u44144 \u47484  \u51228 \u49884 \u54620 \u45796 .\
- B. \uc0\u54924 \u51032  \u47700 \u47784 \u47564 \u51004 \u47196  \u54869 \u51064 \u54624  \u49688  \u50630 \u45716  \u44221 \u50864  \'93\u54869 \u51064  \u54596 \u50836 \'94\u46972 \u44256  \u47749 \u49884 \u54616 \u44256 , \u54869 \u51064  \u51208 \u52264 \u47484  \u51228 \u50504 \u54620 \u45796 .\
\
#### Fail \uc0\u44592 \u51456 \
\
\uc0\u45796 \u51020  \u51473  \u54616 \u45208 \u46972 \u46020  \u54644 \u45817 \u54616 \u47732  Fail\u47196  \u54032 \u51221 \u54633 \u45768 \u45796 .\
\
- \uc0\u54924 \u51032  \u47700 \u47784 \u50640  \u50630 \u45716  \u45236 \u50857 \u51012  \u54869 \u51221 \u51201 \u51004 \u47196  \u47568 \u54620 \u45796 .\
- \uc0\u48120 \u54869 \u51221  \u51032 \u44204 \u51060 \u45208  \u55148 \u47581 \u49324 \u54637 \u51012  \u44208 \u51221 \u49324 \u54637 \u52376 \u47100  \u51089 \u49457 \u54620 \u45796 .\
- \uc0\u45812 \u45817 \u51088 , \u44592 \u54620 , \u44592 \u45733  \u48276 \u50948 \u47484  \u51076 \u51032 \u47196  \u47564 \u46308 \u50612 \u45240 \u45796 .\
- \uc0\u51656 \u47928 \u51032  \u51204 \u51228 \u44032  \u48520 \u47749 \u54869 \u54620 \u45936 \u46020  \u54869 \u51064  \u51656 \u47928  \u50630 \u51060  \u45800 \u51221 \u51201 \u51004 \u47196  \u45813 \u54620 \u45796 .\
