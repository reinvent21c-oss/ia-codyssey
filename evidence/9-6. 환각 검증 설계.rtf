- \uc0\u45800 \u49692 \u55176  \u51473 \u50836 \u54616 \u45796 \u44256  \u50616 \u44553 \u46108  \u45236 \u50857 \u51012  \u54869 \u51221  \u47700 \u45684  \u44396 \u49457 \u51004 \u47196  \u51089 \u49457 \u54616 \u47732  Fail\u51077 \u45768 \u45796 .\
