\f0\fs26 \cf0 ## 9-1. \uc0\u47928 \u51228  \u51221 \u51032  \u44592 \u52488  \u51221 \u47532 \
\
### 1. \uc0\u53440 \u44191  \u49324 \u50857 \u51088 \
\uc0\u50937 \u50640 \u51060 \u51204 \u49884 \u50640 \u49436  B2B \u51228 \u51312 \u44592 \u50629  \u54856 \u54168 \u51060 \u51648  \u47532 \u45684 \u50620  \u54532 \u47196 \u51229 \u53944 \u47484  \u44288 \u47532 \u54616 \u45716  \u44592 \u54925 \u51088  \u46608 \u45716  \u54532 \u47196 \u51229 \u53944  \u45812 \u45817 \u51088 (PM)\
\
### 2. \uc0\u50629 \u47924  \u47928 \u51228 \
\uc0\u53413 \u50724 \u54532  \u54924 \u51032  \u51060 \u54980  \u44208 \u51221 \u49324 \u54637 , \u51032 \u44204 , \u54869 \u51064  \u54596 \u50836  \u49324 \u54637 , \u54980 \u49549  \u49892 \u54665  \u54637 \u47785 (Action Items)\u51060  \u49438 \u50668  \u51221 \u47532 \u46104 \u47732  \u54980 \u49549  \u50629 \u47924  \u45572 \u46973 \u51060 \u45208  \u52964 \u48036 \u45768 \u52992 \u51060 \u49496  \u50724 \u47448 \u44032  \u48156 \u49373 \u54624  \u49688  \u51080 \u49845 \u45768 \u45796 .\
\
\uc0\u53945 \u55176  \u54869 \u51221 \u46104 \u51648  \u50506 \u51008  \u51032 \u44204 \u51060  \u44208 \u51221 \u49324 \u54637 \u52376 \u47100  \u44592 \u47197 \u46104 \u44144 \u45208 , \u45812 \u45817 \u51088 \u48324  \u54980 \u49549  \u49892 \u54665  \u54637 \u47785 \u51060  \u47749 \u54869 \u55176  \u48516 \u47532 \u46104 \u51648  \u50506 \u51004 \u47732  \u51068 \u51221  \u51648 \u50672 \u44284  \u51116 \u54869 \u51064  \u48708 \u50857 \u51060  \u48156 \u49373 \u54624  \u49688  \u51080 \u49845 \u45768 \u45796 .\
\
### 3. \uc0\u51077 \u47141  \u45936 \u51060 \u53552  \u54805 \u53468 \
\uc0\u48708 \u51221 \u54805  \u54924 \u51032  \u47700 \u47784 , \u45433 \u52712  \u50836 \u50557 \u48376 , \u54924 \u51032  \u51473  \u48156 \u50616  \u47700 \u47784 , \u53364 \u46972 \u51060 \u50616 \u53944  \u50836 \u44396 \u49324 \u54637  \u47700 \u47784 \u47484  \u51077 \u47141  \u45936 \u51060 \u53552 \u47196  \u49324 \u50857 \u54633 \u45768 \u45796 .\
\
### 4. \uc0\u52636 \u47141  \u44508 \u44201 \
\uc0\u44592 \u48376  \u52636 \u47141 \u51008  \u49324 \u45236  \u44277 \u50976 \u50857  \u54924 \u51032 \u47197 \u51004 \u47196  \u54633 \u45768 \u45796 .\
\
\uc0\u54924 \u51032  \u47785 \u51201 , \u44208 \u51221 \u49324 \u54637 , \u54980 \u49549  \u49892 \u54665  \u54637 \u47785 , \u54869 \u51064 \u46108  \u49324 \u49892 , \u44032 \u45733 \u54620  \u47532 \u49828 \u53356 , \u54869 \u51064  \u54596 \u50836  \u49324 \u54637 , \u54980 \u49549  \u51068 \u51221 \u51004 \u47196  \u44396 \u48516 \u54644  \u51089 \u49457 \u54633 \u45768 \u45796 .\
\
\uc0\u45800 , \u49324 \u50857 \u51088 \u44032  \u50836 \u52397 \u54624  \u44221 \u50864  \u53364 \u46972 \u51060 \u50616 \u53944  \u51204 \u45804 \u50857  \u54924 \u51032 \u47197 \u51004 \u47196  \u48320 \u54872 \u54624  \u49688  \u51080 \u51004 \u47728 , \u51060  \u44221 \u50864  \u45236 \u48512  \u47532 \u49828 \u53356  \u54032 \u45800 \u51060 \u45208  \u45236 \u48512  \u45812 \u45817 \u51088  \u44036  \u51312 \u50984  \u45236 \u50857 \u51008  \u51649 \u51217 \u51201 \u51004 \u47196  \u45432 \u52636 \u54616 \u51648  \u50506 \u44256  \u51221 \u51228 \u46108  \u54364 \u54788 \u51004 \u47196  \u51089 \u49457 \u54633 \u45768 \u45796 .}